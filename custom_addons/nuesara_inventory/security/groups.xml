<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_nuesara_inventory" model="ir.module.category">
        <field name="name">Nuesara Inventory</field>
        <field name="description">Helps you manage inventory for Bar &amp; Kitchen.</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_nuesara_staf" model="res.groups">
        <field name="name">Staf Bar &amp; Kitchen</field>
        <field name="category_id" ref="module_category_nuesara_inventory"/>
    </record>

    <record id="group_nuesara_head" model="res.groups">
        <field name="name">Head Divisi</field>
        <field name="category_id" ref="module_category_nuesara_inventory"/>
        <field name="implied_ids" eval="[(5, 0, 0)]"/>
    </record>

    <record id="group_nuesara_finance" model="res.groups">
        <field name="name">Divisi Finance</field>
        <field name="category_id" ref="module_category_nuesara_inventory"/>
    </record>

    <record id="group_nuesara_owner" model="res.groups">
        <field name="name">Owner</field>
        <field name="category_id" ref="module_category_nuesara_inventory"/>
    </record>

    <record id="group_nuesara_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_nuesara_inventory"/>
        <field name="implied_ids" eval="[(4, ref('group_nuesara_head')), (4, ref('group_nuesara_finance'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
