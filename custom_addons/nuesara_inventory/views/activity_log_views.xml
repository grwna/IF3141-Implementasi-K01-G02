<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nuesara_activity_log_tree" model="ir.ui.view">
            <field name="name">nuesara.activity.log.tree</field>
            <field name="model">nuesara.activity.log</field>
            <field name="arch" type="xml">
                <tree create="0" edit="0" delete="0">
                    <field name="timestamp"/>
                    <field name="user_id"/>
                    <field name="action"/>
                    <field name="model_name"/>
                    <field name="record_name"/>
                    <field name="note"/>
                </tree>
            </field>
        </record>

        <record id="view_nuesara_activity_log_search" model="ir.ui.view">
            <field name="name">nuesara.activity.log.search</field>
            <field name="model">nuesara.activity.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="user_id"/>
                    <field name="action"/>
                    <field name="model_name"/>
                    <group expand="0" string="Group By">
                        <filter string="Pengguna" name="group_user" context="{'group_by': 'user_id'}"/>
                        <filter string="Jenis Aktivitas" name="group_action" context="{'group_by': 'action'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_nuesara_activity_log" model="ir.actions.act_window">
            <field name="name">Log Aktivitas</field>
            <field name="res_model">nuesara.activity.log</field>
            <field name="view_mode">tree</field>
        </record>
    </data>
</odoo>
