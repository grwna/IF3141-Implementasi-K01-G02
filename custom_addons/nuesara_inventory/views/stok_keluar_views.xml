<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Action -->
        <record id="action_stok_keluar" model="ir.actions.act_window">
            <field name="name">Pemakaian Harian</field>
            <field name="res_model">stok.keluar</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Tree View -->
        <record id="view_stok_keluar_tree" model="ir.ui.view">
            <field name="name">stok.keluar.tree</field>
            <field name="model">stok.keluar</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="tanggal"/>
                    <field name="shift"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_stok_keluar_form" model="ir.ui.view">
            <field name="name">stok.keluar.form</field>
            <field name="model">stok.keluar</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_usage" string="Simpan" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="tanggal"/>
                            </group>
                            <group>
                                <field name="shift"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lines" name="lines">
                                <field name="line_ids">
                                    <tree editable="bottom">
                                        <field name="bahan_id"/>
                                        <field name="jumlah_pakai"/>
                                        <field name="satuan"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
