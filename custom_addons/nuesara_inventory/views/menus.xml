<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Root Menu -->
        <menuitem id="nuesara_inventory_root_menu"
                  name="Nuesara Inventory"
                  web_icon="base,static/description/icon.png"
                  sequence="1"/>

        <!-- Dashboard: View only -->
        <menuitem id="nuesara_dashboard_menu"
                  name="Dashboard Inventory"
                  parent="nuesara_inventory_root_menu"
                  action="action_bahan_baku_dashboard"
                  sequence="1"/>

        <!-- Master Data -->
        <menuitem id="nuesara_master_data_menu"
                  name="Master Data"
                  parent="nuesara_inventory_root_menu"
                  sequence="10"/>

        <!-- Master Bahan Baku: For Input -->
        <menuitem id="nuesara_bahan_baku_menu"
                  name="Master Bahan Baku"
                  parent="nuesara_master_data_menu"
                  action="action_bahan_baku_master"
                  sequence="10"/>

        <!-- Transactions -->
        <menuitem id="nuesara_transactions_menu"
                  name="Transactions"
                  parent="nuesara_inventory_root_menu"
                  sequence="20"/>

        <menuitem id="nuesara_stok_masuk_menu"
                  name="Input Stok Masuk"
                  parent="nuesara_transactions_menu"
                  action="action_stok_masuk"
                  sequence="10"/>

        <menuitem id="nuesara_stok_keluar_menu"
                  name="Pencatatan Pemakaian Harian"
                  parent="nuesara_transactions_menu"
                  action="action_stok_keluar"
                  sequence="20"/>

        <!-- Reporting -->
        <menuitem id="nuesara_reporting_menu"
                  name="Reporting"
                  parent="nuesara_inventory_root_menu"
                  groups="nuesara_inventory.group_nuesara_finance,nuesara_inventory.group_nuesara_admin"
                  sequence="30"/>

        <menuitem id="nuesara_rekonsiliasi_menu"
                  name="Rekonsiliasi Keuangan"
                  parent="nuesara_reporting_menu"
                  action="nuesara_inventory.action_rekonsiliasi"
                  sequence="10"/>

        <!-- Configuration -->
        <menuitem id="nuesara_config_menu"
                  name="Configuration"
                  parent="nuesara_inventory_root_menu"
                  sequence="40"/>

        <menuitem id="nuesara_profile_menu"
                  name="Profil Saya"
                  parent="nuesara_config_menu"
                  action="base.action_res_users_my"
                  sequence="10"/>
    </data>
</odoo>
